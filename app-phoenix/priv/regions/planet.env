# Planet-scale: full Earth via planet.openstreetmap.org + Komoot's planet Photon bundle
# Expect ~1.5 TB on disk and ~1 week first-boot (Overpass dominates).

REGION_NAME=planet
REGION_LABEL="Planet (Earth)"
COUNTRY_CODE=
PBF_URL=https://planet.openstreetmap.org/pbf/planet-latest.osm.pbf
PBF_NAME=planet-latest.osm.pbf
OVERPASS_DIFF_URL=https://planet.openstreetmap.org/replication/minute/
DEFAULT_LAT=0
DEFAULT_LON=0
DEFAULT_ZOOM=2
