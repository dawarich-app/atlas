# City-scale: Berlin via BBBike
# ~30 MB PBF; Valhalla/Overpass/OTP all ingest just this; Photon still falls back
# to country (DE) since Komoot doesn't publish city bundles.

REGION_NAME=berlin
REGION_LABEL="Berlin (city)"
COUNTRY_CODE=de
PBF_URL=https://download.bbbike.org/osm/bbbike/Berlin/Berlin.osm.pbf
PBF_NAME=Berlin.osm.pbf
OVERPASS_DIFF_URL=
DEFAULT_LAT=52.520008
DEFAULT_LON=13.404954
DEFAULT_ZOOM=11

# Transit (OTP) — VBB regional GTFS feed (Cloudflare-redirected → real zip)
GTFS_URL=https://www.vbb.de/fileadmin/user_upload/VBB/Dokumente/API-Datensaetze/gtfs-mastscharf/GTFS.zip
GTFS_NAME=vbb.gtfs.zip
