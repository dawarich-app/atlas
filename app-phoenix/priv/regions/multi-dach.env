# Multi-country example: DACH (Germany + Austria + Switzerland)
# REGIONS= triggers the merge flow in `make region`; PBF_URL becomes a derived
# `data/osm/merged.osm.pbf` produced via osmium-tool from the listed sources.

REGION_NAME=dach
REGION_LABEL="DACH (DE + AT + CH)"
COUNTRY_CODE=de
REGIONS="de,at,ch"
PBF_URLS="https://download.geofabrik.de/europe/germany-latest.osm.pbf https://download.geofabrik.de/europe/austria-latest.osm.pbf https://download.geofabrik.de/europe/switzerland-latest.osm.pbf"
PBF_URL=local://data/osm/dach-merged.osm.pbf
PBF_NAME=dach-merged.osm.pbf
OVERPASS_DIFF_URL=
DEFAULT_LAT=48.5
DEFAULT_LON=11.0
DEFAULT_ZOOM=5
