# Multi-city example: Berlin + Vienna via BBBike
# Same merge mechanism as country-multi; just BBBike URLs.

REGION_NAME=berlin-vienna
REGION_LABEL="Berlin + Vienna"
COUNTRY_CODE=de
REGIONS="berlin,vienna"
PBF_URLS="https://download.bbbike.org/osm/bbbike/Berlin/Berlin.osm.pbf https://download.bbbike.org/osm/bbbike/Wien/Wien.osm.pbf"
PBF_URL=local://data/osm/berlin-vienna-merged.osm.pbf
PBF_NAME=berlin-vienna-merged.osm.pbf
OVERPASS_DIFF_URL=
DEFAULT_LAT=49.5
DEFAULT_LON=14.0
DEFAULT_ZOOM=6
