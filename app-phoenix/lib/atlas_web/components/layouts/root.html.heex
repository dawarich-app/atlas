<!DOCTYPE html>
<html lang="en" data-theme="forest-patina">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="application-name" content="Dawarich Atlas" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Dawarich Atlas">{assigns[:page_title]}</.live_title>

    <link rel="icon" type="image/svg+xml" href={~p"/icon.svg"} />
    <link rel="icon" type="image/png" sizes="32x32" href={~p"/icon.png"} />
    <link rel="apple-touch-icon" href={~p"/icon.png"} />

    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-base-100 text-base-content h-screen overflow-hidden">
    {@inner_content}
  </body>
</html>
