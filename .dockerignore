# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for more about ignoring files.

# Ignore git directory.
/.git/
/.gitignore
/.gitattributes
/.github

# Ignore bundler config.
/.bundle

# Ignore all environment files (NEVER ship local secrets).
/.env
/.env.*

# Ignore all default key files.
/config/master.key
/config/credentials/*.key

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore Active Storage local files.
/storage/*
!/storage/.keep

# Ignore assets.
/node_modules/
/app/assets/builds/*
!/app/assets/builds/.keep
# Widget loader bundle is checked in (small, hand-built, ships to third-party sites).
!/app/assets/builds/widget.v1.js
/public/assets

# Ignore Kamal files.
/config/deploy*.yml
/.kamal

# Ignore development files.
/.devcontainer

# Ignore Docker-related files.
/.dockerignore
/Dockerfile*

# Ignore tests and coverage artifacts (not needed in image).
/spec/
/test/
/.rspec
/coverage/

# Ignore plan/spec docs.
/docs/superpowers/

# Editor / OS junk.
/.idea
/.vscode
.DS_Store
*.swp
*.swo
