# Atlas .env — everything in this file is OPTIONAL. The defaults below are
# baked into compose.yml and the app entrypoint; copy this only if you want
# to override something.
#
# SECRET_KEY_BASE: auto-generated on first boot and persisted to
#   data/app/.secret_key_base (under the bind-mounted volume). Set this
#   yourself only if you want to share a key across hosts.
# DATABASE_PATH: SQLite path inside the app container; defaults to
#   /data/atlas.sqlite3 (data/app/atlas.sqlite3 on the host).
# DATABASE_URL: leave unset for SQLite. To use Postgres, set a
#   postgres:// URL AND use an image built with ATLAS_DB_ADAPTER=postgres.
#
# SECRET_KEY_BASE=replace-with-output-of-openssl-rand-hex-64
# DATABASE_PATH=/data/atlas.sqlite3
# DATABASE_URL=postgres://user:pass@host:5432/atlas

# DOCKER_GID: REQUIRED for the in-app control plane (Settings → apply:
#   region downloads + sidecar start/stop/update). The app runs as `nobody`
#   and talks to the host docker socket via this supplementary group, so it
#   MUST match the host's docker group GID:
#       getent group docker | cut -d: -f3      # Linux, typically 998 or 999
#   Without the correct value the maps API still works against already-running
#   sidecars, but the admin panel cannot manage them. (macOS Docker Desktop
#   does not expose the socket this way — control plane is Linux-only.)
# DOCKER_GID=999

# Region selection (ISO-2 country code; see Geofabrik for valid extracts)
COUNTRY_CODE=de
PBF_URL=https://download.geofabrik.de/europe/germany-latest.osm.pbf
PBF_NAME=germany-latest.osm.pbf
OVERPASS_DIFF_URL=https://download.geofabrik.de/europe/germany-updates/

# NOTE: pelias/whosonfirst:latest currently IGNORES this — it always pulls the global
# WOF bundle (~68 GB transient, ~3-6 GB final store). Kept here for forward-compat in case
# the upstream image restores country filtering.
WHOSONFIRST_COUNTRY_CODE=de

# Set to False to skip SRTM download in Valhalla (saves ~3–30 GB per region).
BUILD_ELEVATION=True
