# chibichange — example environment file.
# Copy this to `.env` and fill in the blanks before running `docker compose up`.

# REQUIRED ----------------------------------------------------------------

# The hostname your chibichange instance is reachable at.
# This is used in URLs (sign-in redirects, public changelog links, RSS feeds).
# Examples: changes.example.org, chibi.localhost (for local testing).
CHIBICHANGE_HOST=localhost

# The Rails master key. Generate this ONCE on a machine with the chibichange
# source by running: `EDITOR=true bin/rails credentials:edit` and copying the
# value from config/master.key. Treat this like a password — anyone with it
# can decrypt your credentials.
RAILS_MASTER_KEY=

# Postgres connection string. Use the value below if you're running the
# bundled `db` service in docker-compose.yml; change `db` to your host's
# IP/DNS if you point at an external Postgres.
DATABASE_URL=postgres://chibichange:chibichange@db:5432/chibichange_production

# OPTIONAL ----------------------------------------------------------------

# Where the embed snippet's <script src=...> points. Defaults to
# https://${CHIBICHANGE_HOST}. Set this only if you're fronting the widget
# with a CDN/edge alias.
# CHIBICHANGE_WIDGET_HOST=https://cdn.example.com

# Force HTTPS (default: true). Set to "false" if you're running behind a
# reverse proxy that handles SSL termination AND chibichange itself only
# sees HTTP traffic.
# CHIBICHANGE_FORCE_SSL=true

# GitHub OAuth — optional. If unset, only Devise email/password sign-in
# works. To enable GitHub OAuth, register an OAuth App at
# https://github.com/settings/developers and copy the credentials here.
# Authorization callback URL must be:
#   https://${CHIBICHANGE_HOST}/users/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Puma tuning (defaults shown).
# RAILS_MAX_THREADS=5
# WEB_CONCURRENCY=2

# Email / SMTP — optional. Without SMTP_SERVER, the app does not attempt SMTP
# delivery (password-reset emails won't send). Set these to enable email.
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=
# SMTP_DOMAIN=example.com
# SMTP_AUTHENTICATION=plain        # plain | login | cram_md5 | ...
# SMTP_STARTTLS=true
# SMTP_FROM=no-reply@example.com   # "From" address on outgoing mail

# Error monitoring + analytics via PostHog — optional. No-op unless set.
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com
# POSTHOG_PERSONAL_API_KEY=
